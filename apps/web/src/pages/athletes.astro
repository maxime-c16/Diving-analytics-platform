---
export const prerender = false;

import { AthleteDirectoryView } from "../components/AthleteDirectoryView";
import AppLayout from "../layouts/AppLayout.astro";

const response = await fetch("http://127.0.0.1:4101/athletes");
const initialAthletes = response.ok ? await response.json() : [];
---

<AppLayout
  title="Athletes"
  description="Search the athlete directory, compare profile depth, and open a dedicated diver workspace with performance, competition, and dive history."
  pathname="/athletes"
>
  <script is:inline>
    {`const legacyId = new URLSearchParams(window.location.search).get("id"); if (legacyId) window.location.replace("/athletes/" + legacyId);`}
  </script>
  <AthleteDirectoryView client:load initialList={initialAthletes} />
</AppLayout>
