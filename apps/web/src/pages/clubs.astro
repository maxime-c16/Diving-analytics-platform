---
export const prerender = false;

import { ClubDirectoryView } from "../components/ClubDirectoryView";
import AppLayout from "../layouts/AppLayout.astro";

const response = await fetch("http://127.0.0.1:4101/clubs");
const initialClubs = response.ok ? await response.json() : [];
---

<AppLayout
  breadcrumbs={[{ href: "/", label: "Overview" }, { label: "Clubs" }]}
  title="Clubs"
  description="Review club rosters, recent competition presence, event-family coverage, and direct navigation into athlete and competition contexts."
  pathname="/clubs"
>
  <ClubDirectoryView client:load initialList={initialClubs} />
</AppLayout>
