---
import { AthleteProfileView } from "../../components/AthleteProfileView";
import AppLayout from "../../layouts/AppLayout.astro";

export async function getStaticPaths() {
  const response = await fetch("http://127.0.0.1:4101/athletes");
  const athletes = (await response.json()) as Array<{ id: number }>;
  return athletes.map((athlete) => ({
    params: { id: String(athlete.id) },
  }));
}

const { id } = Astro.params;
const initialDetail = id
  ? await fetch(`http://127.0.0.1:4101/athletes/${id}`).then((response) =>
      response.ok ? response.json() : null,
    )
  : null;
---

<AppLayout
  breadcrumbs={
    initialDetail
      ? [
          { href: "/", label: "Overview" },
          { href: "/athletes", label: "Athletes" },
          { label: initialDetail.athlete.name },
        ]
      : [
          { href: "/", label: "Overview" },
          { href: "/athletes", label: "Athletes" },
          { label: "Diver Profile" },
        ]
  }
  title="Diver Profile"
  description="A dedicated athlete workspace that stays connected to competitions, event families, synchro partners, and dive-level performance."
  pathname="/athletes"
>
  <AthleteProfileView athleteId={id || ""} client:load initialDetail={initialDetail} />
</AppLayout>
