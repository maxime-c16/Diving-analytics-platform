---
import { ClubProfileView } from "../../components/ClubProfileView";
import AppLayout from "../../layouts/AppLayout.astro";

export async function getStaticPaths() {
  const response = await fetch("http://127.0.0.1:4101/clubs");
  const clubs = (await response.json()) as Array<{ slug: string }>;
  return clubs.map((club) => ({
    params: { slug: club.slug },
  }));
}

const { slug } = Astro.params;
const initialDetail = slug
  ? await fetch(`http://127.0.0.1:4101/clubs/${slug}`).then((response) =>
      response.ok ? response.json() : null,
    )
  : null;
---

<AppLayout
  breadcrumbs={
    initialDetail
      ? [
          { href: "/", label: "Overview" },
          { href: "/clubs", label: "Clubs" },
          { label: initialDetail.club.name },
        ]
      : [
          { href: "/", label: "Overview" },
          { href: "/clubs", label: "Clubs" },
          { label: "Club Profile" },
        ]
  }
  title="Club Profile"
  description="A club-level workspace with roster coverage, competition-level deep links, recent dives, and direct navigation into athlete profiles."
  pathname="/clubs"
>
  <ClubProfileView clubSlug={slug || ""} client:load initialDetail={initialDetail} />
</AppLayout>
