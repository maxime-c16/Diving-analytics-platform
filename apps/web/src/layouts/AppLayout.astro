---
import { ClientRouter } from "astro:transitions";
import "../styles/app.css";

type BreadcrumbItem = {
  href?: string;
  label: string;
};

const { title, description, pathname = "/", breadcrumbs = [] } = Astro.props as {
  title: string;
  description: string;
  pathname?: string;
  breadcrumbs?: BreadcrumbItem[];
};

const navItems = [
  { href: "/", label: "Overview" },
  { href: "/upload", label: "Results Intake" },
  { href: "/competitions", label: "Competitions" },
  { href: "/athletes", label: "Athletes" },
  { href: "/clubs", label: "Clubs" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="brand">
          <strong>Diving Analytics</strong>
          <span>Competition intelligence, athlete profiling, club analysis</span>
        </div>

        <nav class="nav">
          {navItems.map((item) => (
            <a href={item.href} data-active={pathname === item.href}>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="sidebar-note">Structured result intake, linked competition workspaces, and dive-level review.</div>
      </aside>

      <main class="content">
        <header class="page-header">
          <div>
            {breadcrumbs.length > 0 ? (
              <nav aria-label="Breadcrumb" class="breadcrumb-trail">
                <ol>
                  {breadcrumbs.map((item, index) => (
                    <li>
                      {item.href && index < breadcrumbs.length - 1 ? (
                        <a href={item.href}>{item.label}</a>
                      ) : (
                        <span aria-current={index === breadcrumbs.length - 1 ? "page" : undefined}>
                          {item.label}
                        </span>
                      )}
                    </li>
                  ))}
                </ol>
              </nav>
            ) : null}
            <h1>{title}</h1>
            <p>{description}</p>
          </div>
        </header>
        <slot />
      </main>
    </div>
  </body>
</html>
