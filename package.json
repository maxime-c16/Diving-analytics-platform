{
  "name": "diving-analytics-platform",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "cd apps/api && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "check:web": "cd apps/web && bun run astro check",
    "smoke:web": "node scripts/smoke-greenfield.mjs",
    "smoke:greenfield": "node scripts/smoke-greenfield.mjs"
  }
}
